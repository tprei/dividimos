<!--
  Dividimos notification icon. FCM fills the alpha channel with
  default_notification_color (notification_accent orange), so the shapes
  below appear as an orange silhouette on the Android status bar.

  Design mirrors src/components/shared/logo.tsx: a rounded square frame
  around the three-shape glyph (left dot, vertical pill, right dot).
  The outer square is drawn as a 2dp stroke rather than a fill so it
  reads as a recognizable frame rather than a solid blob at 24dp.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">
    <!-- Outer rounded square frame (stroked) -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFFFF"
        android:strokeWidth="2"
        android:pathData="M7.5,2 L16.5,2 A5.5,5.5 0 0,1 22,7.5 L22,16.5 A5.5,5.5 0 0,1 16.5,22 L7.5,22 A5.5,5.5 0 0,1 2,16.5 L2,7.5 A5.5,5.5 0 0,1 7.5,2 Z" />
    <!-- Left dot -->
    <path
        android:fillColor="#FFFFFFFF"
        android:pathData="M5,12 A2,2 0 1,0 9,12 A2,2 0 1,0 5,12 Z" />
    <!-- Center vertical pill -->
    <path
        android:fillColor="#FFFFFFFF"
        android:pathData="M10.5,8 A1.5,1.5 0 0,1 13.5,8 L13.5,16 A1.5,1.5 0 0,1 10.5,16 Z" />
    <!-- Right dot -->
    <path
        android:fillColor="#FFFFFFFF"
        android:pathData="M15,12 A2,2 0 1,0 19,12 A2,2 0 1,0 15,12 Z" />
</vector>
