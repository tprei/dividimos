# Supabase credentials
# Option A (local): run ./scripts/dev-setup.sh — it fills these automatically
# Option B (remote): copy from your Supabase project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# AES-256-GCM key for Pix key encryption (64 hex chars)
# Generate with: openssl rand -hex 32
PIX_ENCRYPTION_KEY=generate-with-openssl-rand-hex-32

# Twilio Verify — used for phone-based 2FA
# Create a Verify Service at https://console.twilio.com/verify/services
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_VERIFY_SERVICE_SID=your-twilio-verify-service-sid

# Enable test auth mode (phone OTP accepts any 6-digit code, dev login API enabled)
# When true, 2FA verification is bypassed — any 6-digit code is accepted
NEXT_PUBLIC_AUTH_PHONE_TEST_MODE=true
