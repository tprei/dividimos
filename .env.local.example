# Supabase credentials
# Option A (local): run ./scripts/dev-setup.sh — it fills these automatically
# Option B (remote): copy from your Supabase project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# AES-256-GCM key for Pix key encryption (64 hex chars)
# Generate with: openssl rand -hex 32
PIX_ENCRYPTION_KEY=generate-with-openssl-rand-hex-32

# Enable dev login API endpoint (email-based, auto-creates users)
# Set to false (or omit) in production — the endpoint also requires DEV_LOGIN_SECRET
DEV_LOGIN_ENABLED=false

# Shared secret for the dev login endpoint — required for the route to activate.
# Generate with: openssl rand -hex 32
# The caller must pass this value in the x-dev-login-secret request header.
DEV_LOGIN_SECRET=
